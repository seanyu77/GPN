# GP web — environment template
#
# NOTE: NEXT_PUBLIC_* vars are inlined into the client bundle at BUILD time,
# NOT read at runtime. This MUST be set when you run `npm run build`.
#
# Production (single-domain, path-based routing through the reverse proxy):
NEXT_PUBLIC_SIGNALING_URL=wss://app.example.com/ws

# Local dev default (used automatically if unset): ws://localhost:3001
