# GP signaling server — environment template
# Copy to .env for local use, or set these in the systemd unit for production.

# Port the signaling HTTP/WebSocket server listens on (behind the reverse proxy).
PORT=3001

# --- WebRTC media network (REQUIRED in production) ---
# Interface mediasoup binds to. 0.0.0.0 = all interfaces (use in production).
MEDIASOUP_LISTEN_IP=0.0.0.0
# The server's PUBLIC IPv4 address, announced to clients in ICE candidates.
# WITHOUT this, remote clients connect to signaling but get NO media.
MEDIASOUP_ANNOUNCED_IP=YOUR_PUBLIC_IP

# --- RTC media port range (must be open in the firewall, UDP + TCP) ---
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
